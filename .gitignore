# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Go
# 二进制产物（/vigil 仅匹配根目录编译产物，勿用 vigil 通配以免误伤 cmd/vigil 目录）
/bin/
*.exe
/vigil
cmd/vigil/vigil
# 测试覆盖率
*.out
coverage.txt
# 依赖（Go Modules 走版本控制，不忽略 vendor 时单独处理）

# 本地环境 / 密钥
.env
.env.local
*.secret

# 数据库本地文件（开发用 sqlite 等）
*.db
*.sqlite
*.sqlite3

# 前端
node_modules/
build/
web/node_modules/
web/dist/
# 前端 embed 产物：构建时由 web/dist 复制到 internal/web/dist，不入库但保留占位。
# 用 dist/*（而非 dist/）忽略目录内容，使 !.gitkeep 反忽略能生效
# （git 对 dir/ 形式不会进入目录，反忽略内部文件无效）。
internal/web/dist/*
!internal/web/dist/.gitkeep
# pnpm
.pnpm-store/

# Git worktree（开发用，特性分支隔离的工作目录，详见 AGENTS.md「开发约定」）
.worktree/

# 日志
*.log
/genmigration
cmd/genmigration/genmigration

# Playwright MCP 浏览器评审临时快照（QA 用，不入库）
.playwright-mcp/
