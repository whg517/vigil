# Vigil 环境变量配置示例。
# 复制为 .env 并按需修改。所有变量前缀 VIGIL_。
#
# ⚠️ 注意：行内 # 会被 shell 解析为值的一部分，
#    注释请写在独立行（不要放在值后面）。

# ===== 应用 =====
# development | production
VIGIL_APP_ENV=development
# debug | info | warn | error
VIGIL_APP_LOG_LEVEL=info

# ===== HTTP =====
VIGIL_HTTP_ADDR=:8080

# ===== PostgreSQL =====
# ⚠️ 务必显式设置（envconfig 嵌套 default 在部分场景不生效）
VIGIL_DB_HOST=127.0.0.1
VIGIL_DB_PORT=5432
VIGIL_DB_USER=vigil
VIGIL_DB_PASSWORD=vigil
VIGIL_DB_NAME=vigil
# disable | require | verify-full
VIGIL_DB_SSL_MODE=disable

# ===== Redis（缓存/队列/锁）=====
VIGIL_REDIS_ADDR=127.0.0.1:6379
VIGIL_REDIS_PASSWORD=
VIGIL_REDIS_DB=0

# ===== Asynq 异步任务 =====
# worker 并发数
VIGIL_ASYNQ_CONCURRENCY=10

# ===== 鉴权（能力域 13）=====
# 是否强制业务 API 鉴权（默认 true，SEC-02）。
# development：可设 false 便于本地调试（业务 API 匿名放行 + 允许 X-Vigil-User-ID 头注入）。
# production：强制 true（显式 false 也会被忽略），且必须配置 JWT_SECRET，否则启动失败。
VIGIL_AUTH_ENABLED=true
# JWT 签名密钥。
# 开发模式（development）无需设置，系统自动填充默认值，可直接登录。
# 生产模式必须设置强随机字符串，缺失则启动失败。
VIGIL_AUTH_JWT_SECRET=
# access token 有效期（默认 15m）
VIGIL_AUTH_ACCESS_TOKEN_TTL=15m
# refresh token 有效期（默认 720h=30d）
VIGIL_AUTH_REFRESH_TOKEN_TTL=720h
# 首次启动且配了 JWT_SECRET 时自动创建默认管理员 admin/changeme，请立即改密

# ===== LLM / AI（能力域 11，智谱 GLM）=====
# 为空时 AI 功能自动降级（复盘/诊断走规则草稿）
VIGIL_LLM_API_KEY=
VIGIL_LLM_MODEL=glm-4-flash
VIGIL_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# 成本控制（缓存/限流/配额，无 Redis 时全部降级跳过）
# Complete 缓存 TTL（秒）
VIGIL_LLM_COST_CACHE_TTL_SECONDS=3600
# true 关闭缓存（调试）
VIGIL_LLM_COST_DISABLE_CACHE=false
# 每分钟最大请求数，0=不限
VIGIL_LLM_COST_RATE_LIMIT_PER_MIN=0
# token 累计配额，0=不限
VIGIL_LLM_COST_TOKEN_QUOTA=0

# ===== IM 协同（能力域 8，飞书 + 钉钉）=====
# 各平台凭证为空时该平台禁用（降级不发送）
VIGIL_IM_FEISHU_APP_ID=
VIGIL_IM_FEISHU_APP_SECRET=
VIGIL_IM_FEISHU_VERIFICATION_TOKEN=
VIGIL_IM_FEISHU_ENCRYPT_KEY=
# 企业内部应用 AppKey
VIGIL_IM_DINGTALK_APP_KEY=
# 企业内部应用 AppSecret
VIGIL_IM_DINGTALK_APP_SECRET=
# 机器人编码，缺省等于 AppKey
VIGIL_IM_DINGTALK_ROBOT_CODE=
# 事件订阅校验 token（配回调时填）
VIGIL_IM_DINGTALK_TOKEN=
# 事件订阅加密密钥（AES-256-CBC，base64 43 字符；配回调时填）
VIGIL_IM_DINGTALK_AES_KEY=
# 值班群 chat_id / openConversationId（告警卡片发送目标）
VIGIL_IM_ONCALL_CHANNEL=

# ===== Webhook 出口（能力域 14）=====
# incident 生命周期事件推送给外部订阅者，逗号分隔多个 URL
VIGIL_WEBHOOK_OUT_URLS=

# ===== 接入限流/背压（能力域 1，M1.7）=====
# 保护系统不被单个告警源拖垮。无 Redis 时降级跳过（放行，可用性优先）。
# 单个接入点每分钟最大请求数（0=不限流）
VIGIL_INGESTION_RATE_LIMIT_PER_MIN=600
# 队列积压阈值，超过接入层返回 503（payload 仍落库，0=不检查）
VIGIL_INGESTION_BACKPRESSURE_DEPTH=10000

# ===== 分诊窗口（能力域 3-4，C9）=====
# 去重/聚合窗口可配（默认 5m）。窗口过小易裂单（长风暴每窗口新建一单），
# 过大易误聚合无关故障——按告警源特性调整。支持 Go duration（如 30s / 2m / 1h）。
# 去重窗口：同 dedup_key 在窗口内重复直接丢弃
VIGIL_TRIAGE_DEDUP_WINDOW=5m
# 聚合窗口：同 service+severity 在窗口内并入同一 Incident
VIGIL_TRIAGE_AGGREGATE_WINDOW=5m

# ===== 通知通道（能力域 7）=====
# 邮件（M7.3）：SMTP 配置后真实发送，未配置降级跳过。
# SMTP 服务器（如 smtp.example.com），空=禁用邮件
VIGIL_NOTIFICATION_SMTP_HOST=
# 端口（25/465/587）
VIGIL_NOTIFICATION_SMTP_PORT=25
# 认证用户名，空=匿名发送
VIGIL_NOTIFICATION_SMTP_USERNAME=
# 认证密码
VIGIL_NOTIFICATION_SMTP_PASSWORD=
# 发件人地址，空=vigil@localhost
VIGIL_NOTIFICATION_SMTP_FROM=
# 电话/SMS（M7.2，本期占位）：转发 webhook 供你对接云语音 API（阿里云/腾讯云）。
# 配置后通知会 POST 到此 URL（payload 含事件+号码），真实云厂商对接见 TODO.md。
# 语音通知接收端点，空=禁用电话
VIGIL_NOTIFICATION_PHONE_WEBHOOK_URL=
# 短信通知接收端点，空=禁用短信
VIGIL_NOTIFICATION_SMS_WEBHOOK_URL=

# ===== 凭据加密托管（能力域 9 Runbook 执行器，T6.3/S16）=====
# AES-256 对称密钥，托管 Runbook 执行器访问外部平台（Ansible/Jenkins）的 token 等凭据：
# DB 存密文，执行时解密注入 Authorization 头（明文绝不落 step/日志/时间线）。
# base64 或 hex 编码的 32 字节密钥。生成：openssl rand -base64 32（或 rand -hex 32）。
# ⚠️ 绝不硬编码/提交 git。空=凭据托管未启用（凭据创建/更新端点返 503，既有加密数据不受影响）。
VIGIL_CREDENTIAL_ENCRYPTION_KEY=

# ===== Event/RawEvent 保留清理（平台化长尾，T6.2/M15）=====
# Event 是海量不可变的原始信号（只追加），无保留策略会长期堆积吃存储。
# 清理巡检周期删除超保留期的旧 Event/RawEvent。★ 安全：只删关联 Incident 已 closed（或无关联）
# 的 Event——活跃处置证据不删；批量分页避免锁表。<=0 表示对应类型不清理（永不删）。
# Event 保留天数（默认 90，约一季度覆盖复盘/审计回溯；0=不清理）
VIGIL_RETENTION_EVENT_DAYS=90
# RawEvent 保留天数（默认 30，原始 payload 体积大、价值衰减快；0=不清理）
VIGIL_RETENTION_RAW_EVENT_DAYS=30
# 清理巡检间隔（Go duration，默认 6h，低频后台任务）
VIGIL_RETENTION_INTERVAL=6h
# 单批删除上限（分页，默认 500，避免大事务锁表）
VIGIL_RETENTION_BATCH_SIZE=500
