# Vigil 环境变量配置示例。
# 复制为 .env 并按需修改。所有变量前缀 VIGIL_。
# ⚠️ 注意：envconfig 对嵌套字段的 default 在部分场景不生效，
#    数据库/Redis 凭证务必显式设置（不要依赖默认值）。

# ===== 应用 =====
VIGIL_APP_ENV=development              # development | production
VIGIL_APP_LOG_LEVEL=info               # debug | info | warn | error

# ===== HTTP =====
VIGIL_HTTP_ADDR=:8080                  # 监听地址

# ===== PostgreSQL =====
# ⚠️ 务必显式设置（嵌套 default 可能不生效）
VIGIL_DB_HOST=127.0.0.1
VIGIL_DB_PORT=5432
VIGIL_DB_USER=vigil
VIGIL_DB_PASSWORD=vigil
VIGIL_DB_NAME=vigil
VIGIL_DB_SSL_MODE=disable              # disable | require | verify-full

# ===== Redis（缓存/队列/锁）=====
VIGIL_REDIS_ADDR=127.0.0.1:6379
VIGIL_REDIS_PASSWORD=
VIGIL_REDIS_DB=0

# ===== Asynq 异步任务 =====
VIGIL_ASYNQ_CONCURRENCY=10             # worker 并发数

# ===== 鉴权（能力域 13）=====
VIGIL_AUTH_ENABLED=false               # true 时业务 API 强制身份解析（JWT 优先，回退 X-Vigil-User-ID）
VIGIL_AUTH_JWT_SECRET=                 # JWT 签名密钥，生产必填（空=登录降级，拒绝签发）
VIGIL_AUTH_ACCESS_TOKEN_TTL=15m        # access token 有效期（默认 15m）
VIGIL_AUTH_REFRESH_TOKEN_TTL=720h      # refresh token 有效期（默认 720h=30d）
# 首次启动且配了 JWT_SECRET 时自动创建默认管理员 admin/changeme，请立即改密

# ===== LLM / AI（能力域 11，智谱 GLM）=====
# 为空时 AI 功能自动降级（复盘/诊断走规则草稿）
VIGIL_LLM_API_KEY=                     # 智谱 API Key
VIGIL_LLM_MODEL=glm-4-flash
VIGIL_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# 成本控制（缓存/限流/配额，无 Redis 时全部降级跳过）
VIGIL_LLM_COST_CACHE_TTL_SECONDS=3600  # Complete 缓存 TTL（秒）
VIGIL_LLM_COST_DISABLE_CACHE=false     # true 关闭缓存（调试）
VIGIL_LLM_COST_RATE_LIMIT_PER_MIN=0    # 每分钟最大请求数，0=不限
VIGIL_LLM_COST_TOKEN_QUOTA=0           # token 累计配额，0=不限

# ===== IM 协同（能力域 8，飞书 + 钉钉）=====
# 各平台凭证为空时该平台禁用（降级不发送）
VIGIL_IM_FEISHU_APP_ID=
VIGIL_IM_FEISHU_APP_SECRET=
VIGIL_IM_FEISHU_VERIFICATION_TOKEN=
VIGIL_IM_FEISHU_ENCRYPT_KEY=
VIGIL_IM_DINGTALK_APP_KEY=             # 企业内部应用 AppKey
VIGIL_IM_DINGTALK_APP_SECRET=          # 企业内部应用 AppSecret
VIGIL_IM_DINGTALK_ROBOT_CODE=          # 机器人编码，缺省等于 AppKey
VIGIL_IM_DINGTALK_TOKEN=               # 事件订阅校验 token（配回调时填）
VIGIL_IM_DINGTALK_AES_KEY=             # 事件订阅加密密钥（AES-256-CBC，base64 43 字符；配回调时填）
VIGIL_IM_ONCALL_CHANNEL=               # 值班群 chat_id / openConversationId（告警卡片发送目标）

# ===== Webhook 出口（能力域 14）=====
# incident 生命周期事件推送给外部订阅者，逗号分隔多个 URL
VIGIL_WEBHOOK_OUT_URLS=

# ===== 接入限流/背压（能力域 1，M1.7）=====
# 保护系统不被单个告警源拖垮。无 Redis 时降级跳过（放行，可用性优先）。
VIGIL_INGESTION_RATE_LIMIT_PER_MIN=600     # 单个接入点每分钟最大请求数（0=不限流）
VIGIL_INGESTION_BACKPRESSURE_DEPTH=10000   # 队列积压阈值，超过接入层返回 503（payload 仍落库，0=不检查）
